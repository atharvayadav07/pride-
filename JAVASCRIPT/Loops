<!DOCTYPE html>
<html>
<head>
  <title>JavaScript Loops with writeln()</title>
</head>
<body>

<h2>JavaScript Loops Example</h2>

<script>
                             // For Loop: prints 1 to 5
  document.writeln("For Loop:<br>");
  for (let i = 1; i <= 5; i++) {
    document.writeln(i);
  }

  document.writeln("<br>");

                           // While Loop: prints 1 to 3
  document.writeln("While Loop:<br>");
  let j = 1;
  while (j <= 3) {
    document.writeln(j);
    j++;
  }

  document.writeln("<br>");

                        // Do-While Loop: prints 1 to 3
  document.writeln("Do-While Loop:<br>");
  let k = 1;
  do {
    document.writeln(k);
    k++;
  } while (k <= 3);
</script>

</body>
</html>
